{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atelier",
  "version": "0.1.67",
  "identifier": "com.jean.desktop",
  "build": {
    "removeUnusedCommands": true,
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atelier",
        "width": 800,
        "height": 600,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "alwaysOnTop": false,
        "transparent": true,
        "shadow": true,
        "dragDropEnabled": false,
        "windowEffects": {
          "effects": ["sidebar"],
          "radius": 12,
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' ipc: http://ipc.localhost https://ipc.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost data: blob: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/.jean/images/**", "$APPDATA/**"],
          "requireLiteralLeadingDot": false
        }
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "resources": {
      "../dist": "dist/"
    },
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "JB Holdings SIA",
    "category": "DeveloperTool",
    "shortDescription": "Atelier - AI Development Workspace",
    "longDescription": "Atelier is an AI development workspace built with Tauri, React, and TypeScript.",
    "copyright": "Copyright © 2026 JB Holdings SIA. All rights reserved.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": "Developer ID Application: JB Holdings SIA (SQ47CHL585)",
      "providerShortName": "SQ47CHL585",
      "entitlements": null,
      "exceptionDomain": ""
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/BowgartField/atelier/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3QjI5MzM1REE1MUNFQ0IKUldUTHpsSGFOWk95VjNGYUYyM09ENWp5YkY5NThLTHFuMVcvYzg4Vjk5UEl0QnY3UXowZ0RGU0YK"
    }
  }
}
